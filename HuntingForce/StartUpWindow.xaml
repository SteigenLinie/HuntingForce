                    <RowDefinition Height="0.5*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="0.5*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="1">
                    <Image Grid.Row="1"
                           Source="C:\Users\SteigenLinie\Downloads\logo\new_button2_black.png"
                           MouseMove="Image2_MouseMove"
                           MouseLeave="Image2_MouseLeave"
                           MouseLeftButtonUp="Play_MouseLeftButtonUp"/>
                    <TextBlock Text="Play"
                               Grid.Row="1"
                               Foreground="White"
                               Opacity="0.8"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               FontFamily="/Resources/Fonts/#Determination2"
                               FontSize="55"
                               MouseMove="Image2_MouseMove"
                               MouseLeave="Image2_MouseLeave"
                               MouseLeftButtonUp="Play_MouseLeftButtonUp"/>
                </Grid>
                <Grid Grid.Row="2">
                    <Image Grid.Row="2"
                           Source="C:\Users\SteigenLinie\Downloads\logo\new_button_black.png"
