                           MouseLeave="Image_MouseLeave"/>
                    <TextBlock Text="Settings"
                               Grid.Row="2"
                               Foreground="White"
                               Opacity="0.8"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               FontFamily="/Resources/Fonts/#Determination2"
                               FontSize="55"
                               MouseMove="Image_MouseMove"
                               MouseLeave="Image_MouseLeave"/>
                </Grid>
                <Grid Grid.Row="3">
                    <Image Source="C:\Users\SteigenLinie\Downloads\logo\new_button_black.png"
                           MouseMove="Image_MouseMove"
                           MouseLeave="Image_MouseLeave"/>
                    <TextBlock Text="Load"
                               Foreground="White"
                               Opacity="0.8"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               FontFamily="/Resources/Fonts/#Determination2"
                               FontSize="55"
                               MouseMove="Image_MouseMove"
                               MouseLeave="Image_MouseLeave"/>
                </Grid>
                <Grid Grid.Row="4">
                    <Image Source="C:\Users\SteigenLinie\Downloads\logo\new_button_black.png"
                           MouseMove="Image_MouseMove"
                           MouseLeave="Image_MouseLeave"/>
                    <TextBlock Text="Psychological help"
                               Foreground="White"
                               Opacity="0.8"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               FontFamily="/Resources/Fonts/#Determination2"
                               FontSize="35"
