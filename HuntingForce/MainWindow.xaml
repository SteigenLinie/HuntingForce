                    <RowDefinition Height="1.25*"/>
                    <RowDefinition Height="1.25*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="0.5*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0"
                          Grid.RowSpan="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Width="175"
                            Height="30"
                            Margin="50 0 0 0"
                            BorderBrush="Gray"
                            BorderThickness="2 2 2 0"
                            HorizontalAlignment="Left">
                        <TextBlock Text="{Binding NameForDialog}"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="25"
                                   FontFamily="./Resources/Fonts/#Determination2"/>
                    </Border>
                    <Border Background="Black"
                            BorderBrush="Gray"
                            BorderThickness="2"
                            Grid.Row="1"
                            Grid.RowSpan="2"
                            Margin="20 0 80 5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto">
                                <TextBlock Text="{Binding Dialog}"
                                           Margin="10 10 20 10"
                                           FontSize="20"
                                           TextWrapping="Wrap"
                                           FontFamily="./Resources/Fonts/#Determination2"/>
                                <!--MouseLeftButtonDown="TextBlock_MouseLeftButtonDown"-->
                            </ScrollViewer>
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Button Grid.Row="1"
                                        Content="History"
                                        Height="Auto"
                                        VerticalContentAlignment="Bottom"
                                        HorizontalAlignment="Center"
                                        Padding="0"
                                        FontFamily="./Resources/Fonts/#Determination2"
                                        Click="History_Click"
                                        Style="{StaticResource MaterialDesignFlatButton}"/>

                                <Button Grid.Column="2" 
                                        Grid.RowSpan="2"
                                        Background="Black"
                                        BorderThickness="0"
                                        BorderBrush="Transparent"
                                        Padding="0"
                                        Margin="0 0 2 2"
                                        Height="32"
                                        Width="32"
                                        Command="{Binding SkipDialog}">
                                    <materialDesign:PackIcon Kind="PlayArrow"
                                                             Height="32"
                                                             Width="32"/>
                                </Button>
                            </Grid>
                        </Grid>
                    </Border>

                </Grid>
